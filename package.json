{
  "name": "mcp-asksql",
  "version": "1.6.2",
  "description": "MCP server for natural language SQL queries across 10+ databases",
  "type": "module",
  "license": "MIT",
  "author": "Jianmin Wei",
  "homepage": "https://github.com/df360-net/MCP-AskSQL",
  "repository": {
    "type": "git",
    "url": "https://github.com/df360-net/MCP-AskSQL.git"
  },
  "keywords": [
    "mcp",
    "asksql",
    "sql",
    "database",
    "natural-language",
    "ai",
    "llm",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node build/index.js --http --port 8081",
    "start:stdio": "node build/index.js --stdio",
    "build": "tsc && npm run build:ui",
    "build:ui": "webpack --config webpack.config.js --mode production",
    "dev": "tsc && node build/index.js --http --port 8081",
    "dev:ui": "webpack serve --config webpack.config.js --mode development",
    "test": "npx --node-options=--experimental-vm-modules jest",
    "test:watch": "npx --node-options=--experimental-vm-modules jest --watch",
    "test:coverage": "npx --node-options=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@databricks/sql": "^1.13.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.10.1",
    "express": "^4.21.2",
    "marked": "^18.0.0",
    "md-to-pdf": "^5.2.5",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "nodemailer": "^8.0.5",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.5",
    "snowflake-sdk": "^2.3.5",
    "teradatasql": "^20.0.54",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.23.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/marked": "^5.0.2",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.11.16",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/snowflake-sdk": "^1.6.24",
    "@types/supertest": "^6.0.2",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.7.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
