{
  "name": "mcp-asksql",
  "version": "1.0.0",
  "description": "MCP server for natural language SQL queries across 10+ databases",
  "type": "module",
  "license": "MIT",
  "author": "Jianmin Wei",
  "homepage": "https://github.com/df360-net/MCP-AskSQL",
  "repository": {
    "type": "git",
    "url": "https://github.com/df360-net/MCP-AskSQL.git"
  },
  "keywords": [
    "mcp",
    "asksql",
    "sql",
    "database",
    "natural-language",
    "ai",
    "llm",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "tsx src/index.ts --http --port 8080",
    "start:stdio": "tsx src/index.ts --stdio",
    "build": "tsc && npm run build:ui",
    "build:ui": "vite build --config src/ui/vite.config.ts",
    "dev": "tsx watch src/index.ts --http --port 8080",
    "dev:ui": "vite --config src/ui/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@databricks/sql": "^1.13.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@modelcontextprotocol/sdk": "^1.10.1",
    "express": "^5.1.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.5",
    "snowflake-sdk": "^2.3.5",
    "teradatasql": "^20.0.54",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.1",
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.14.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/snowflake-sdk": "^1.6.24",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.0",
    "vitest": "^3.2.4"
  }
}
